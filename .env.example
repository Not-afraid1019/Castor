# LLM (required)
CASTOR_LLM_API_KEY=sk-xxx
CASTOR_LLM_BASEURL=https://api.openai.com/v1
CASTOR_LLM_MODEL_NAME=gpt-4o
# CASTOR_LLM_PROTOCOL=openai        # openai | anthropic, auto-detect if omitted
# CASTOR_LLM_MAX_TOKENS=4096        # optional, leave unset to use model's full capacity

# Feishu (required for bot mode)
CASTOR_FEISHU_APP_ID=cli_xxx
CASTOR_FEISHU_APP_SECRET=xxx

# Web Search (optional)
CASTOR_WEB_SEARCH_PROVIDER=tavily
CASTOR_WEB_SEARCH_API_KEY=tvly-xxx

# Agent (optional, has defaults)
CASTOR_DATA_DIR=./data
# CASTOR_WORKSPACE_DIR=./workspace   # Files outside this dir require user confirmation
CASTOR_SCRIPT_TIMEOUT=30000
# CASTOR_MAX_CONVERSATION_MESSAGES=50  # optional, leave unset for unlimited history
