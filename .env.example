# LLM (required)
LLM_API_KEY=sk-xxx
LLM_BASEURL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_PROTOCOL=openai          # openai | anthropic, auto-detect if omitted
LLM_MAX_TOKENS=4096

# Feishu (required for bot mode)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Web Search (optional)
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=tvly-xxx

# Agent (optional, has defaults)
DATA_DIR=./data
SCRIPT_TIMEOUT=30000
MAX_CONVERSATION_MESSAGES=50
